class Solution {
    vector<int> calc_z(const string& s) {
        int n = s.size();
        vector<int> z(n);
        int box_l = 0, box_r = 0; 
        for (int i = 1; i < n; i++) {
            if (i <= box_r) {
                z[i] = min(z[i - box_l], box_r - i + 1);
            }
            while (i + z[i] < n && s[z[i]] == s[i + z[i]]) {
                box_l = i;
                box_r = i + z[i];
                z[i]++;
            }
        }
        z[0] = n;
        return z;
    }

public:
    string generateString(string s, string t) {
        int n = s.size(), m = t.size();
        string ans(n + m - 1, '?');

        vector<int> z = calc_z(t);
        int pre = -m;
        for (int i = 0; i < n; i++) {
            if (s[i] != 'T') {
                continue;
            }
            int size = max(pre + m - i, 0);
            if (size > 0 && z[m - size] < size) {
                return "";
            }
            for (int j = size; j < m; j++) {
                ans[i + j] = t[j];
            }
            pre = i;
        }

        vector<int> pre_q(ans.size());
        pre = -1;
        for (int i = 0; i < ans.size(); i++) {
            if (ans[i] == '?') {
                ans[i] = 'a'; 
                pre = i;
            }
            pre_q[i] = pre;
        }

        z = calc_z(t + ans);

        for (int i = 0; i < n; i++) {
            if (s[i] != 'F') {
                continue;
            }
            if (z[m + i] < m) {
                continue;
            }
            int j = pre_q[i + m - 1];
            if (j < i) { 
                return "";
            }
            ans[j] = 'b';
            i = j; 
        }

        return ans;
    }
};
